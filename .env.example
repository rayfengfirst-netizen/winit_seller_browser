# Copy to .env and fill in (never commit .env)
WINIT_USERNAME=your_account
WINIT_PASSWORD=your_password
# 密码里若有 #：末尾写成 xxx# 没问题；若 # 前面有空格（如 xxx #）会被当成注释截断。
# 含空格、# 或不确定时，请用双引号包起来，例如：
# WINIT_PASSWORD="my pass#word"

# --- 多账号（可选；解析逻辑见 winit_accounts.py）---
# 账号 1 即上面的 WINIT_USERNAME / WINIT_PASSWORD，或显式写：
# WINIT_ACCOUNT_1_USERNAME=
# WINIT_ACCOUNT_1_PASSWORD=
# WINIT_ACCOUNT_1_LABEL=主店
# 第二个账号起必须带编号（连续 2、3…）：
# WINIT_ACCOUNT_2_USERNAME=second@example.com
# WINIT_ACCOUNT_2_PASSWORD=second_password
# WINIT_ACCOUNT_2_LABEL=分店
# 单次任务用哪个账号（默认 1）
# WINIT_ACCOUNT_ID=2
# step02 / login_winit：按顺序跑完全部已配置账号（各启一次浏览器）
# WINIT_RUN_ALL_ACCOUNTS=1
# 是否按账号分子目录保存下载（未设置时：配置≥2个账号则自动分目录；设为 0 强制同一目录）
# WINIT_DOWNLOAD_PER_ACCOUNT=1

# Optional: headless=true on server after selectors work
WINIT_HEADLESS=false

# Optional: max wait (ms) for login form password field to appear; default 45000
# WINIT_FORM_WAIT_MS=45000

# Optional: default is https://seller.winit.com.cn/User/login
# WINIT_LOGIN_URL=https://seller.winit.com.cn/User/login

# --- 第一步：登录后进入 Australia 首页 step01_australia_index.py ---
# WINIT_AUSTRALIA_INDEX_URL=https://seller.winit.com.cn/Australia/index

# --- 第二步：澳大利亚导出 SKU 仓库库存 step02_australia_export.py ---
# 导出中心列表里匹配任务行（默认 海外仓库存，不写死日期）
# WINIT_EXPORT_ROW_MATCH=海外仓库存
# 该行状态变为以下文案后再点「保存到本地」（默认 导出成功；之前可能是 正在生成）
# WINIT_EXPORT_READY_STATUS=导出成功
# 下载链接文案（可用 | 写多个，依次尝试；站点常见为「保存本地」）
# WINIT_EXPORT_SAVE_TEXT=保存本地|保存到本地
# 若出现则立即失败（默认 导出失败）
# WINIT_EXPORT_FAIL_STATUS=导出失败
# 等待状态从「正在生成」变为就绪的最长时间（毫秒）
# WINIT_STEP02_EXPORT_READY_WAIT_MS=180000
# 上面等待过程中每段 wait_for 的步长（毫秒）
# WINIT_STEP02_EXPORT_STATUS_POLL_MS=1500
# WINIT_STEP02_DOWNLOAD_TIMEOUT_MS=120000
# 以下用于 Australia 页 iframe 加载较慢时加大等待（毫秒）
# WINIT_STEP02_IFRAME_WAIT_MS=90000
# WINIT_STEP02_EXPORT_POLL_MS=90000
# WINIT_STEP02_AFTER_GOTO_WAIT_MS=1200
# 主文档上点「导出」：进入轮询前预检超时（毫秒）；按钮在壳层而非 iframe 时可省掉多轮嵌套探测
# WINIT_STEP02_EXPORT_MAIN_PREFLIGHT_MS=3200
# 每轮轮询里优先尝试主文档的超时（毫秒），再跑嵌套 iframe（避免 ~7s/轮空转）
# WINIT_STEP02_EXPORT_MAIN_PROBE_MS=1200
# 每轮末尾对主文档的补试超时（毫秒）
# WINIT_STEP02_EXPORT_MAIN_CLICK_MS=2400
# 进入 Australia 后，在 #pageTabContent iframe 内等「导出」出现（毫秒）
# WINIT_STEP02_EXPORT_BUTTON_HINT_MS=18000
# 上述等待的上限（毫秒），避免一上来卡太久
# WINIT_STEP02_EXPORT_BUTTON_HINT_CAP_MS=4500
# 嵌套 iframe：先等「导出」控件 visible（毫秒），再 click（见下一项）
# WINIT_STEP02_NESTED_EXPORT_VISIBLE_MS=2200
# visible 已满足后，单次 click 的超时（毫秒）
# WINIT_STEP02_NESTED_EXPORT_CLICK_MS=15000
# 未等到 visible 时，短超时试探点击（毫秒），避免每轮 4×4500 空转
# WINIT_STEP02_NESTED_EXPORT_PROBE_MS=750
# get_by_text 探测「导出」时的 is_visible 超时（毫秒，越小越快但可能漏判）
# WINIT_STEP02_EXPORT_TEXT_PROBE_MS=200
# 轮询点「导出」的间隔（毫秒）
# WINIT_STEP02_EXPORT_POLL_STEP_MS=300
# 每个 iframe 内先等「导出」控件 visible 的最长时间（毫秒）；过小会多轮轮询
# WINIT_STEP02_EXPORT_FRAME_GATE_MS=600
# 通过门禁后在单 frame 内每次 click 的超时（毫秒）
# WINIT_STEP02_EXPORT_IN_FRAME_CLICK_MS=1800
# 点顶栏「海外仓库存」后等待（毫秒）
# WINIT_STEP02_AFTER_OVERSEAS_TAB_MS=700
# WINIT_STEP02_AFTER_OVERSEAS_GAP_MS=600
# WINIT_STEP02_AFTER_SUBTAB_MS=500
# 调试：截图 + 打印所有 frame URL
# WINIT_STEP02_DEBUG=1
# 性能：终端打印每阶段累计/间隔耗时（把整段日志发我即可定位慢在哪）
# WINIT_STEP02_PROFILE=1
# 性能：结束生成 trace zip，用「playwright show-trace 路径」逐操作回放（文件较大）
# WINIT_STEP02_TRACE=1
# 视口（避免「导出」在首屏外）
# WINIT_VIEWPORT_WIDTH=1920
# WINIT_VIEWPORT_HEIGHT=1080
# 若库存页有国家子 Tab，导出前需点到对应 Tab（例：澳大利亚）
# WINIT_STEP02_SUBTAB=澳大利亚
# 若必须先点「查询」才出现导出按钮
# WINIT_STEP02_CLICK_QUERY=1
# 点「确定」后等待导出配置弹窗关闭（毫秒），再跳转导出中心
# WINIT_STEP02_EXPORT_SUCCESS_WAIT_MS=90000
# WINIT_STEP02_AFTER_OK_MS=800
# 弹窗关闭检测轮询间隔（毫秒）
# WINIT_STEP02_EXPORT_SUCCESS_POLL_MS=200
# 进入导出中心后短等待再解析表格（毫秒）
# WINIT_STEP02_EXPORT_CENTER_SETTLE_MS=400
# 等待 #exportDataList 出现在 DOM（毫秒），再进入下载逻辑
# WINIT_STEP02_EXPORT_CENTER_SHELL_MS=20000
# 精确指定导出列表容器（页面有多个 #exportDataList 时用）
# WINIT_EXPORT_DATA_LIST_CSS=#root .winitd-card-body #exportDataList
# 始终点列表第一条（调试用，确认是否选错行）
# WINIT_EXPORT_USE_FIRST_LI=1
# 导出中心页 wait_for_load_state(load) 超时（毫秒）
# WINIT_STEP02_EXPORT_CENTER_LOAD_MS=20000
# 等待列表 iframe/主文档出现（毫秒；仅「定位表格区域」，默认已缩短）
# WINIT_STEP02_EXPORT_CENTER_READY_MS=15000
# WINIT_STEP02_EXPORT_CENTER_POLL_MS=250
# 探测 iframe 时单次 attach 超时（毫秒，勿过大，否则轮询会像卡住）
# WINIT_STEP02_EXPORT_IFRAME_ATTACH_MS=2500
# 导出中心「列表区域」轮询里：#pageTabContent iframe 存在时才等（毫秒）
# WINIT_STEP02_PAGE_TAB_IFRAME_MS=1500
# 导出中心页探测第 n 个 iframe 的超时（毫秒，宜短）
# #exportDataList 内匹配 li 的 attached 超时（毫秒）；主表格优先后此项仅作备选，宜短
# WINIT_STEP02_EXPORT_LIST_LI_WAIT_MS=12000
# #exportDataList 轮询「保存」就绪的最长时间（毫秒）；顶栏误匹配时避免空转过久，超时后回退 iframe/ant-table
# WINIT_STEP02_EXPORT_LIST_POLL_CAP_MS=45000
# WINIT_STEP02_EXPORT_LIST_IFRAME_MS=800
# 定位超时后兜底取 iframe[0] 的 attach 超时（毫秒）
# WINIT_STEP02_EXPORT_LIST_FALLBACK_IFRAME_MS=1200
# 页面已显示后，等「含 WINIT_EXPORT_ROW_MATCH 的数据行」出现（后台生成任务可能慢）
# WINIT_STEP02_EXPORT_ROW_WAIT_MS=120000
# 点「导出」打开弹窗后的短暂间隔（毫秒）
# WINIT_STEP02_AFTER_EXPORT_CLICK_MS=350
# 导出中心页 URL（默认如下）
# WINIT_EXPORT_CENTER_URL=https://seller.winit.com.cn/ExportCenter/index
# 仅调试：跳过「弹窗关闭」判定（不推荐）
# WINIT_STEP02_SKIP_SUCCESS_GATE=1

# --- 下载文件 download_winit.py（与 login 共用账号密码；等你录好步骤再接）---
# 方式 A：使用流程文件（复制 download_flow.example.json 为 download_flow.json 并修改）
# WINIT_DOWNLOAD_FLOW_FILE=/绝对或相对路径/download_flow.json
# 方式 B：简单模式（无 flow 文件时）：登录后打开页面再点匹配按钮
# WINIT_DOWNLOAD_PAGE_URL=https://seller.winit.com.cn/某报表页
# WINIT_DOWNLOAD_NAME_PATTERN=导出|下载|Excel
# WINIT_DOWNLOAD_TIMEOUT_MS=120000
# WINIT_DOWNLOAD_DIR=./downloads
# step03 解压 zip 的根目录（默认 <WINIT_DOWNLOAD_DIR>/extracted）
# WINIT_EXTRACT_BASE=./downloads/extracted

# --- 每日入库 run_daily_winit_job.py（SQLite）---
# 库存快照库路径（默认 artifacts/winit_inventory.db）
# WINIT_SQLITE_PATH=/opt/winit-analytics/artifacts/winit_inventory.db
# 仅重跑入库、不打开浏览器（用各账号下载目录下最新 zip）
# WINIT_SKIP_DOWNLOAD=1
# 快照业务日期 YYYY-MM-DD（默认当天）
# WINIT_SNAPSHOT_DATE=2026-03-23
# --- 飞书机器人（多场景，整段 URL，勿提交到 Git；泄露后请在飞书里重置）---
# 约定：WINIT_FEISHU_WEBHOOK_<场景大写>；代码里 channel 为小写+下划线。
# 入库/下载完成通知（推荐显式配置；不配 SYNC 时仍可读旧变量 URL）
# WINIT_FEISHU_WEBHOOK_SYNC=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx
# WINIT_FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx
# 无动销定时告警（与入库可分不同群；建议北京时间 10:00 跑，见 deploy/winit-no-sales-alert.timer.example）
# WINIT_FEISHU_WEBHOOK_NO_SALES=https://open.feishu.cn/open-apis/bot/v2/hook/yyyyyyyy
# 将来其它脚本可用 feishu_send_text(..., channel="my_alert") + WINIT_FEISHU_WEBHOOK_MY_ALERT
# 飞书消息里「详情」链接的基址（与 inventory_viewer 一致，无尾斜杠；服务器首页常用 8765）
# WINIT_PUBLIC_BASE_URL=http://你的域名或IP:8765
# 无动销预警规则见 winit_no_sales_report.py（按 SKU 聚合各仓；飞书为①②③类 SKU 数，详情为仓库行）
# inventory_viewer.py 监听地址（勿对公网暴露无鉴权服务；生产上常用 8765 作库存首页）
# WINIT_VIEWER_HOST=127.0.0.1
# WINIT_VIEWER_PORT=8765
# 若同时设置用户名与密码，浏览器打开时会提示输入账号密码（HTTP Basic）
# WINIT_VIEWER_USER=winit_readonly
# WINIT_VIEWER_PASSWORD=请换成长随机串
